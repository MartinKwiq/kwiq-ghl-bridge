# =============================================================================
# Kwiq Interview — Variables de entorno locales
# =============================================================================
# NOTA (no-code): con el wizard de /admin/setup ya no hace falta copiar este
# archivo a mano. El wizard escribe `.env.local` automáticamente con las 3
# llaves de Supabase + una INTERVIEW_ENCRYPTION_KEY generada al vuelo, y el
# resto de la config (API keys GHL/LLM, etc.) se edita desde /admin/ajustes.
#
# Este archivo queda como referencia / fallback manual.
#
# Copiar este archivo a `.env.local` y completar. `.env.local` está ignorado por git.
# En Vercel, estas variables se definen en Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo por defecto. Alternativas: gemini-2.5-flash-lite, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# URL pública del proyecto. Para dev local con `supabase start`: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
# Anon key (segura para el cliente, RLS debe estar activo en todas las tablas)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SOLO server-side; nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Selección de proveedor LLM
# -----------------------------------------------------------------------------
# Implementaciones soportadas: "gemini" (default), "claude" (stub), "openai" (stub)
LLM_PROVIDER=gemini

# -----------------------------------------------------------------------------
# Host app
# -----------------------------------------------------------------------------
# Dominio público de la app (se usa en enlaces de la entrevista)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Cifrado de credenciales Kwiq (AES-256-GCM)
# -----------------------------------------------------------------------------
# REQUERIDA en producción. Se usa para cifrar:
#   - PITs de sub-account guardados en kwiq_projects.ghl_token_enc
#   - refresh_tokens de OAuth Marketplace
#   - credenciales sensibles capturadas en la entrevista (activos, APIs, etc.)
# Si falta, `lib/crypto.ts::encryptSecret` lanza error en prod. En dev se deriva
# con SHA-256 como fallback, pero eso no es seguro.
# Generar con: openssl rand -base64 32
INTERVIEW_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# GoHighLevel — Credenciales de agencia Kwiq (modo `pit_agency`)
# -----------------------------------------------------------------------------
# Private Integration Token de la cuenta Agency. Se usa como default para todos
# los proyectos con auth_mode = 'pit_agency' (o sea, los 30 clientes internos
# que viven bajo la agencia Kwiq). No se guarda en DB, vive acá.
# Obtener en: GHL → Settings → Integrations → Private Integrations → Create.
GHL_AGENCY_PIT=

# Company (Agency) ID asociado al PIT de arriba. Opcional pero recomendado.
GHL_AGENCY_COMPANY_ID=

# -----------------------------------------------------------------------------
# GoHighLevel — OAuth Marketplace (modo `oauth_marketplace`, self-service)
# -----------------------------------------------------------------------------
# Completar cuando implementemos el flow de instalación pública. Por ahora
# podés dejar estas vacías.
GHL_MARKETPLACE_CLIENT_ID=
GHL_MARKETPLACE_CLIENT_SECRET=
GHL_MARKETPLACE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Bootstrap del admin Kwiq (scripts/seed-admin.ts)
# -----------------------------------------------------------------------------
# El seed crea el primer admin (martin@kwiq.io) con esta contraseña. Después del
# primer login se puede cambiar desde Supabase Auth (o vía UI más adelante).
# Solo se usa una vez; no hace falta en Vercel.
KWIQ_ADMIN_SEED_EMAIL=martin@kwiq.io
KWIQ_ADMIN_SEED_PASSWORD=Kwiq!Admin-2026#bootstrap

# -----------------------------------------------------------------------------
# URL pública del sitio (usada por /api/admin/logout para armar el redirect)
# -----------------------------------------------------------------------------
# En local: http://localhost:3001. En Vercel: https://interview.kwiq.io (o el
# dominio que configures).
NEXT_PUBLIC_SITE_URL=http://localhost:3001
